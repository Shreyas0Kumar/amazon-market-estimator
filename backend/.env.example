# Required
APP_PIN=your-secret-pin

# Rainforest API (primary scraper)
# Sign up at https://www.rainforestapi.com
RAINFOREST_API_KEY=your-rainforest-api-key

# Scrapingdog (fallback scraper — optional but recommended)
# Sign up at https://www.scrapingdog.com
SCRAPINGDOG_API_KEY=your-scrapingdog-api-key

# OpenAI (for AI-generated summaries — not yet wired)
OPENAI_API_KEY=sk-...

# Cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL_SECONDS=3600
